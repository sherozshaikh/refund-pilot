FROM python:3.13-slim AS runtime
WORKDIR /app
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
RUN apt-get update && apt-get install -y --no-install-recommends libpq5=17.10-0+deb13u1 && rm -rf /var/lib/apt/lists/*
COPY pyproject.toml uv.lock ./
COPY src/ src/
RUN uv sync --frozen --no-dev
ENV PATH="/app/.venv/bin:$PATH"
CMD ["sh", "-c", "celery -A refund_pilot.workers.celery_app worker -Q ${PIPELINE_CELERY_QUEUE_NAME:-refund_requests} --max-tasks-per-child=100 --loglevel=info"]
