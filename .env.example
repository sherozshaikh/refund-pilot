# Claude / Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
PIPELINE_CLAUDE_MAX_TOKENS=300
PIPELINE_CLAUDE_TEMPERATURE=0.0
PIPELINE_CLAUDE_INPUT_COST_PER_MTOK=1.00
PIPELINE_CLAUDE_OUTPUT_COST_PER_MTOK=5.00

# LangSmith
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=refund-pilot

# Database
DATABASE_URL=postgresql+psycopg://refund_pilot:password@postgres:5432/refund_pilot

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# CORS
FRONTEND_URL=http://localhost

# App
SECRET_KEY=
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# Admin first-run bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Pipeline tunables (all optional — PipelineConfig defaults apply)
PIPELINE_MAX_RETRIES=1
PIPELINE_RETRY_WAIT_MIN_SECONDS=1.0
PIPELINE_RETRY_WAIT_MAX_SECONDS=10.0
PIPELINE_TASK_TIMEOUT_SECONDS=60
PIPELINE_CLAUDE_API_TIMEOUT_SECONDS=30
PIPELINE_DB_QUERY_TIMEOUT_SECONDS=5
PIPELINE_ESCALATION_THRESHOLD_USD=500.0
PIPELINE_REFUND_WINDOW_DAYS=30
PIPELINE_MAX_MESSAGE_LENGTH=2000
PIPELINE_MAX_CUSTOMER_ID_LENGTH=36
PIPELINE_CELERY_QUEUE_NAME=refund_requests
PIPELINE_CELERY_MAX_RETRIES=3
PIPELINE_CELERY_RETRY_BACKOFF_SECONDS=5
PIPELINE_FALLBACK_ENABLED=true
PIPELINE_DB_POOL_SIZE=10
PIPELINE_DB_MAX_OVERFLOW=20
PIPELINE_DB_POOL_TIMEOUT_SECONDS=30
PIPELINE_TOOL_CACHE_TTL_SECONDS=1800
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
